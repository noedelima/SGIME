# Variáveis de Ambiente do SGIME
# Sistema de Gestão Integrada de Engenharia
# Colégio Pedro II - Seção de Engenharia
# Licença: GPLv3

# ===== VERSÕES DOS SERVIÇOS (MAIS RECENTES COMPATÍVEIS) =====
REDMINE_VERSION=5.1
RUBY_VERSION=3.2
POSTGRES_VERSION=16
REDIS_VERSION=7
NGINX_VERSION=1.25

# ===== CONFIGURAÇÕES DO BANCO DE DADOS =====
POSTGRES_DB=sgime_production
POSTGRES_USER=sgime_user
POSTGRES_PASSWORD=sgime_senha_segura_2025!
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ===== CONFIGURAÇÕES DO REDIS =====
REDIS_PASSWORD=redis_senha_segura_2025!
REDIS_PORT=6379

# ===== CONFIGURAÇÕES DO REDMINE =====
REDMINE_DB_POSTGRES=postgres
REDMINE_DB_USERNAME=sgime_user
REDMINE_DB_PASSWORD=sgime_senha_segura_2025!
REDMINE_DB_DATABASE=sgime_production
REDMINE_SECRET_KEY_BASE=sua_chave_secreta_muito_segura_aqui_com_pelo_menos_64_caracteres
RAILS_ENV=production

# ===== CONFIGURAÇÕES DE REDE =====
HTTP_PORT=80
HTTPS_PORT=443
REDMINE_PORT=3000
NGINX_PORT=80
NGINX_SSL_PORT=443

# ===== CONFIGURAÇÕES DE EMAIL =====
EMAIL_DELIVERY_METHOD=smtp
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_DOMAIN=cp2.g12.br
SMTP_USERNAME=sgime@cp2.g12.br
SMTP_PASSWORD=senha_email_aplicacao
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true

# ===== CONFIGURAÇÕES DE AUTENTICAÇÃO =====
# LDAP/Active Directory
LDAP_HOST=ldap.cp2.g12.br
LDAP_PORT=389
LDAP_ACCOUNT="CN=sgime-service,OU=Service Accounts,DC=cp2,DC=g12,DC=br"
LDAP_PASSWORD=senha_ldap_service
LDAP_BASE_DN="DC=cp2,DC=g12,DC=br"
LDAP_FILTER=(objectClass=person)

# SSO Azure/Microsoft Entra ID
AZURE_CLIENT_ID=seu_client_id_azure
AZURE_CLIENT_SECRET=seu_client_secret_azure
AZURE_TENANT_ID=seu_tenant_id_azure

# ===== CONFIGURAÇÕES DE BACKUP =====
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE_DB="0 2 * * *"
BACKUP_SCHEDULE_FILES="0 3 * * 0"
BACKUP_STORAGE_PATH=/var/backups/sgime

# ===== CONFIGURAÇÕES DE MONITORAMENTO =====
LOG_LEVEL=info
MAX_LOG_SIZE=100m
LOG_RETENTION=30d

# ===== CONFIGURAÇÕES DE SEGURANÇA =====
SSL_CERT_PATH=/etc/ssl/certs/sgime.crt
SSL_KEY_PATH=/etc/ssl/private/sgime.key
FORCE_SSL=true

# ===== TIMEZONE =====
TZ=America/Sao_Paulo

# ===== CONFIGURAÇÕES ESPECÍFICAS DO SGIME =====
SGIME_VERSION=1.6
SGIME_CONTACT_EMAIL=geeng@cp2.g12.br
SGIME_BASE_URL=https://sgime.cp2.g12.br
ORGANIZATION_NAME="Colégio Pedro II"
DEPARTMENT_NAME="Seção de Engenharia"
