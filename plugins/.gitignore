# SGIME Plugins Directory
# Os plugins são baixados automaticamente dos repositórios oficiais
# Este arquivo garante que não sejam commitados códigos de terceiros

# Ignorar todos os plugins baixados automaticamente
redmine_dashboard/
redmine_recurring_tasks/
simple_checklists/
redmine_issue_templates/
#redmine_dmsf/  # Removido para versionar o plugin local
redmine_agile/

# Plugin baixado manualmente - incluir no versionamento
# redmine_checklists/ está incluído pois foi baixado manualmente (Light version)

# Manter apenas plugins customizados do SGIME
!sgime_customizations/

# Arquivos de configuração temporários
*.tmp
*.log
.DS_Store
Thumbs.db
